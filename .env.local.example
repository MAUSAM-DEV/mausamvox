NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REPLICATE_API_TOKEN=your-replicate-api-token
MVSEP_API_TOKEN=your-mvsep-api-token
# Optional — RVC engine selector: "bare" (default) or "cover" (rollback to the AICoverGen pipeline)
RVC_ENGINE=bare
# ElevenLabs API key — required for Song Studio's default engine (ElevenLabs
# Music, music_v2). Get one at elevenlabs.io (Music API needs a paid plan).
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional — Song Studio engine selector: "elevenlabs" (default) or "acestep"
# (instant rollback to ACE-Step on Replicate; uses REPLICATE_API_TOKEN).
SONG_ENGINE=elevenlabs
